{{> layouts/header}}
<div class="container mt-5">
    <h2>여행 상세 정보</h2>
    <div class="card p-4">
        <h4>{{travelPlan.title}}</h4>
        <p><strong>여행지:</strong> {{travelPlan.destination}}</p>
        <p><strong>기간:</strong> {{travelPlan.startDate}} ~ {{travelPlan.endDate}}</p>
        <p><strong>메모:</strong> {{travelPlan.memo}}</p>
        <div class="mt-3">
            <a href="/travel-plans" class="btn btn-secondary">목록으로</a>
            <a href="/travel-plans/{{travelPlan.id}}/edit" class="btn btn-warning">수정</a>
        </div>
    </div>
</div>
{{> layouts/footer}}