{{> layouts/header}}
<div class="container mt-5" style="max-width: 640px;">
    <h2 class="tp-page-title"><i class="bi bi-pencil-square me-2"></i>여행 일정 수정</h2>
    <div class="card tp-form-card">
        <div class="card-body p-4">
            <form action="/travel-plans/update" method="post">
                <input type="hidden" name="id" value="{{travelPlan.id}}">
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-card-text me-1"></i>제목</label>
                    <input type="text" class="form-control" name="title" value="{{travelPlan.title}}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-geo-alt me-1"></i>여행지</label>
                    <input type="text" class="form-control" name="destination" value="{{travelPlan.destination}}" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><i class="bi bi-calendar-event me-1"></i>시작일</label>
                        <input type="date" class="form-control" name="startDate" value="{{travelPlan.startDate}}" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><i class="bi bi-calendar-check me-1"></i>종료일</label>
                        <input type="date" class="form-control" name="endDate" value="{{travelPlan.endDate}}" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-journal-text me-1"></i>메모</label>
                    <textarea class="form-control" name="memo" rows="3">{{travelPlan.memo}}</textarea>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/travel-plans/{{travelPlan.id}}" class="btn btn-outline-secondary">취소</a>
                    <button type="submit" class="btn btn-tp-primary">
                        <i class="bi bi-check-lg me-1"></i>수정 완료
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{{> layouts/footer}}
