{{> layouts/header}}
<div class="container mt-5">
    <h2>여행 일정 목록</h2>
    <a href="/travel-plans/new" class="btn btn-primary mb-3">새 일정 등록</a>
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th><th>제목</th><th>여행지</th><th>상세보기</th>
            </tr>
        </thead>
        <tbody>
            {{#travelPlans}}
            <tr>
                <td>{{id}}</td><td>{{title}}</td><td>{{destination}}</td>
                <td><a href="/travel-plans/{{id}}" class="btn btn-sm btn-info">보기</a></td>
            </tr>
            {{/travelPlans}}
        </tbody>
    </table>
</div>
{{> layouts/footer}}