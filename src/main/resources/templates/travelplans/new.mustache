{{> layouts/header}}

<div class="container mt-5">
    <h2 class="mb-4">새 여행 일정 등록</h2>

    <form action="/travel-plans/create" method="post" class="border p-4 bg-light rounded">
        <div class="mb-3">
            <label class="form-label fw-bold">제목</label>
            <input type="text" class="form-control" name="title" placeholder="예: 여름 제주도 휴가" required>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">여행지</label>
            <input type="text" class="form-control" name="destination" placeholder="예: 제주특별자치도" required>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">시작일</label>
                <input type="date" class="form-control" name="startDate" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">종료일</label>
                <input type="date" class="form-control" name="endDate" required>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">메모</label>
            <textarea class="form-control" name="memo" rows="5" placeholder="준비물이나 세부 일정을 적어주세요."></textarea>
        </div>

        <button type="submit" class="btn btn-primary">저장하기</button>
        <a href="/travel-plans" class="btn btn-secondary">취소</a>
    </form>
</div>

{{> layouts/footer}}