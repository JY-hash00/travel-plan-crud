{{> layouts/header}}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="tp-page-title mb-0">여행 일정 목록</h2>
        <a href="/travel-plans/new" class="btn btn-tp-primary">
            <i class="bi bi-plus-lg me-1"></i>새 일정 등록
        </a>
    </div>

    <div class="row g-4">
        {{#travelPlans}}
        <div class="col-md-6 col-lg-4">
            <div class="card tp-plan-card">
                <div class="card-header">
                    <i class="bi bi-geo-alt-fill me-2"></i>{{destination}}
                </div>
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">{{title}}</h5>
                    <span class="tp-date-badge align-self-start mb-3">
                        <i class="bi bi-calendar-event me-1"></i>{{startDate}} ~ {{endDate}}
                    </span>
                    <div class="mt-auto d-flex gap-2">
                        <a href="/travel-plans/{{id}}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>보기
                        </a>
                        <a href="/travel-plans/{{id}}/edit" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil me-1"></i>수정
                        </a>
                        <a href="/travel-plans/{{id}}/delete"
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('정말 삭제하시겠습니까?');">
                            <i class="bi bi-trash me-1"></i>삭제
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {{/travelPlans}}
        {{^travelPlans}}
        <div class="col-12">
            <div class="tp-empty">
                <i class="bi bi-airplane display-4 d-block mb-3"></i>
                등록된 여행 일정이 없습니다. 새 일정을 등록해보세요.
            </div>
        </div>
        {{/travelPlans}}
    </div>
</div>
{{> layouts/footer}}
